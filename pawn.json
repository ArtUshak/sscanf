	],
	"entry": "tests/sscanfErr.pwn",
	"output": "gamemodes/sscanfErr.amx",
	"dev_dependencies": ["pawn-lang/samp-stdlib@master"],
	"runtime": {
		"plugins": ["Y-Less/sscanf"],
		"mode": "main"
	},
	"resources": [
		{
			"name": "^sscanf-(.+)-linux.tar.gz$",
			"platform": "linux",
			"archive": true,
			"includes": ["pawno/include"],
			"plugins": ["plugins/sscanf.so"]
		},
		{
			"name": "^sscanf-(.*)-win32.zip$",
			"platform": "windows",
			"archive": true,
			"includes": ["pawno/include"],
			"plugins": ["plugins/sscanf.dll"]
		}
	]
}
